{
  "name": "wiigu-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --no-warnings server/index.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "start": "node --no-warnings server/index.js",
    "test:system": "node --no-warnings server/system-test.js",
    "check": "npm run build && node --no-warnings server/smoke-test.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.7.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7"
  }
}
